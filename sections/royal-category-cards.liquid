{% comment %}
Royal • Categoria Cards v9.2
- Desktop: controle "Encaixar N cards nas bordas" (2–10) sem mudar o tamanho dos círculos
- Gap calculado automaticamente: N*diâmetro + (N-1)*gap = largura do container
- Container alinhado ao restante do tema (largura + gutters)
- Cards: imagem circular + título abaixo (sem fundo)
{% endcomment %}

<section id="royal-cats-{{ section.id }}"
  class="royal-cats
    {% if section.settings.desktop_compact %} desktop-compact{% endif %}">

  {% liquid
    assign is_home = false
    if request.page_type == 'index' or template.name == 'index'
      assign is_home = true
    endif
  %}

  {% render 'royal-overlap', id: section.id %}

  <style>
    #royal-cats-{{ section.id }}{
      /* Diâmetros (mantidos fixos) */
      --diam-d: 120px;          /* desktop padrão */
      --diam-d-compact: 100px;  /* desktop compacto */
      --diam-m: 80px;           /* mobile */

      /* Diâmetro "ativo" no desktop: troca quando liga o compacto */
      --diam-current: var(--diam-d);

      /* Quantos cards devem encaixar entre as bordas no DESKTOP */
      --cards-d: {{ section.settings.desktop_fit_count | default: 5 }};

      /* Gap calculado p/ preencher 100%: (100% - N*diam) / (N-1)
         Com piso de 8px para não colar demais quando N é pequeno. */
      --gap-d-auto: calc((100% - (var(--cards-d) * var(--diam-current))) / (var(--cards-d) - 1));
      --gap: max(8px, var(--gap-d-auto));

      /* Mobile */
      --gap-m: 14px;
      --visible-m: {{ section.settings.mobile_visible | default: 5 }};

      /* Cores e overlap */
      --accent: {{ section.settings.accent | default: '#0E5CF2' }};
      --text: {{ settings.text_color | default: '#111111' }};
      --overlap: {{ section.settings.overlap_px | default: 24 }}px;

      position: relative;
      margin: clamp(8px, 2vw, 20px) 0;
      z-index: 3;
      text-align: center;
    }

    {% if section.settings.overlap_enable %}
    #royal-cats-{{ section.id }}{ margin-top: calc(-1 * var(--overlap)); }
    {% endif %}

    /* ===== Container alinhado ao tema (mesmas extremidades) ===== */
    #royal-cats-{{ section.id }} .container{
      width: 100%;
      max-width: 1480px; /* mesmo max das seções ajustadas */
      margin-left: auto;
      margin-right: auto;
      padding-left: var(--mobile-container-gutter, 20px);
      padding-right: var(--mobile-container-gutter, 20px);
    }
    @media (min-width: 641px) and (max-width: 1023px){
      #royal-cats-{{ section.id }} .container{
        padding-left: var(--tablet-container-gutter, 28px);
        padding-right: var(--tablet-container-gutter, 28px);
      }
    }
    @media (min-width: 1024px){
      #royal-cats-{{ section.id }} .container{
        padding-left: var(--desktop-container-gutter, 36px);
        padding-right: var(--desktop-container-gutter, 36px);
      }
    }
    /* =========================================================== */

    /* Trilho */
    #royal-cats-{{ section.id }} .viewport{ position:relative; overflow:hidden; }
    #royal-cats-{{ section.id }} .track{
      display:flex; flex-wrap:nowrap;
      gap:var(--gap);
      justify-content:flex-start; /* 1º card encosta na esquerda */
      overflow-x:auto; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch;
      padding:0;
    }
    #royal-cats-{{ section.id }} .track::-webkit-scrollbar{ display:none }

    /* Card (sem fundo) */
    #royal-cats-{{ section.id }} .card{
      scroll-snap-align:center;
      width: var(--diam-current);
      min-width: var(--diam-current);
      flex: 0 0 var(--diam-current);
      display:flex; flex-direction:column; align-items:center; gap:8px;
      text-decoration:none; color:var(--text);
      background:transparent!important; box-shadow:none!important; border:0!important;
    }

    .media{
      width: var(--diam-current); height: var(--diam-current);
      border-radius:50%; overflow:hidden; background:transparent!important;
      display:flex; align-items:center; justify-content:center;
      transition: transform .18s ease;
    }
    .card:hover .media{ transform:scale(1.03); }
    .media img{ width:100%; height:100%; object-fit:cover }

    .title{
      font-size:14px; font-weight:600; line-height:1.2;
      max-width:100%; white-space:normal;
      display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
    }

    .badge,.cta{ display:none!important; }

    /* Desktop compacto: só troca o diâmetro "ativo" */
    @media (min-width:992px){
      #royal-cats-{{ section.id }}.desktop-compact{ --diam-current: var(--diam-d-compact); }
    }

    /* Mobile: fração de largura + círculo menor */
    @media (max-width:991px){
      #royal-cats-{{ section.id }} .track{ gap:var(--gap-m); }
      #royal-cats-{{ section.id }} .card{
        min-width: calc((100% - (var(--gap-m) * (var(--visible-m) - 1))) / var(--visible-m));
        flex:0 0 calc((100% - (var(--gap-m) * (var(--visible-m) - 1))) / var(--visible-m));
        width:auto;
      }
      #royal-cats-{{ section.id }} .media{ width:var(--diam-m); height:var(--diam-m); }
      #royal-cats-{{ section.id }} .title{ font-size:12px; }
    }

    /* Setas */
    #royal-cats-{{ section.id }} .nav{
      display:flex; position:absolute; top:50%; transform:translateY(-50%);
      width:40px; height:40px; border-radius:50%; background:#fff; border:none; cursor:pointer;
      box-shadow:0 6px 18px rgba(0,0,0,.15); align-items:center; justify-content:center; z-index:4;
    }
    #royal-cats-{{ section.id }} .nav svg{ width:22px; height:22px }
    #royal-cats-{{ section.id }} .nav.prev{ left:-6px }  #royal-cats-{{ section.id }} .nav.next{ right:-6px }
    #royal-cats-{{ section.id }}.at-start .nav.prev{ display:none; }
    #royal-cats-{{ section.id }}.at-end   .nav.next{ display:none; }
  </style>

  {% unless is_home %}
    <button class="nav prev" aria-label="Anterior">
      <svg viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  {% endunless %}
  <button class="nav next" aria-label="Próximo">
    <svg viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <div class="viewport">
    <div class="container">
      <div class="track">
        {% for block in section.blocks %}
          {% assign col = block.settings.collection %}
          {% assign link = block.settings.link | default: col.url %}
          <a class="card" href="{{ link }}" {{ block.shopify_attributes }}>
            <div class="media">
              {% if block.settings.icon %}
                <img src="{{ block.settings.icon | image_url: width: 300 }}" alt="{{ block.settings.title | escape | default: col.title | escape }}" loading="lazy">
              {% elsif col.image %}
                <img src="{{ col.image | image_url: width: 300 }}" alt="{{ col.title | escape }}" loading="lazy">
              {% else %}
                <svg viewBox="0 0 48 48" width="36" height="36" aria-hidden="true">
                  <defs><clipPath id="r{{ section.id }}"><circle cx="24" cy="24" r="24"/></clipPath></defs>
                  <g clip-path="url(#r{{ section.id }})"><rect x="0" y="0" width="48" height="48" fill="#e9ebee"/></g>
                </svg>
              {% endif %}
            </div>
            <div class="title">{{ block.settings.title | default: col.title }}</div>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>

  <script>
    (function(){
      const root  = document.getElementById('royal-cats-{{ section.id }}');
      const track = root.querySelector('.track');
      const prev  = root.querySelector('.nav.prev');
      const next  = root.querySelector('.nav.next');

      function step(){
        const gap = parseFloat(getComputedStyle(track).gap) || 12;
        const card = track.querySelector('.card');
        if(!card) return 300;
        const w = card.getBoundingClientRect().width;
        return w + gap;
      }
      function updateArrows(){
        const maxScroll = track.scrollWidth - track.clientWidth - 1;
        const atStart = track.scrollLeft <= 0;
        const atEnd   = track.scrollLeft >= maxScroll;
        if (prev) root.classList.toggle('at-start', atStart);
        root.classList.toggle('at-end',   atEnd);
      }
      function go(dir){ track.scrollBy({ left: step() * dir, behavior: 'smooth' }); }
      if (prev) prev.addEventListener('click', () => go(-1));
      if (next) next.addEventListener('click', () => go(1));
      track.addEventListener('scroll', updateArrows);
      window.addEventListener('resize', updateArrows);
      updateArrows();
    })();
  </script>
</section>

{% schema %}
{
  "name": "Royal • Categoria Cards",
  "settings": [
    { "type": "checkbox", "id": "desktop_compact", "label": "Desktop: usar formato compacto", "default": true },

    /* NOVO: quantos cards devem encostar nas bordas no desktop (mantendo o tamanho) */
    { "type": "range", "id": "desktop_fit_count", "label": "Desktop: encaixar N cards nas bordas", "min": 2, "max": 10, "step": 1, "default": 5, "info": "Ajusta apenas o espaçamento. Os círculos mantêm o tamanho." },

    { "type": "range", "id": "mobile_visible", "label": "Cards visíveis (mobile)", "min": 3, "max": 6, "step": 1, "default": 5 },

    { "type": "checkbox", "id": "peek", "label": "Desktop: mostrar indicação de continuação (peek)", "default": true },
    { "type": "checkbox", "id": "mobile_peek", "label": "Mobile: mostrar peek (continuação)", "default": true },

    { "type": "checkbox", "id": "overlap_enable", "label": "Sobrepor um pouco sobre o slideshow", "default": true },
    { "type": "range", "id": "overlap_px", "label": "Tamanho da sobreposição (px)", "min": 0, "max": 80, "step": 2, "default": 24 },

    { "type": "color", "id": "accent", "label": "Cor de destaque", "default": "#0E5CF2" },

    { "type": "range", "id": "media_standard_desktop", "label": "Tamanho do círculo (desktop, px)", "min": 60, "max": 160, "step": 2, "default": 120 },
    { "type": "range", "id": "media_compact_desktop", "label": "Tamanho do círculo (desktop compacto, px)", "min": 60, "max": 140, "step": 2, "default": 100 },
    { "type": "range", "id": "media_compact_mobile", "label": "Tamanho do círculo (mobile, px)", "min": 48, "max": 110, "step": 2, "default": 80 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoria",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Coleção (opcional)" },
        { "type": "image_picker", "id": "icon", "label": "Ícone/Imagem 1:1 (opcional)" },
        { "type": "text", "id": "title", "label": "Título (opcional)" },
        { "type": "url", "id": "link", "label": "Link (se quiser diferente da coleção)" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    { "name": "Royal • Categoria Cards", "category": "Collections" }
  ]
}
{% endschema %}
