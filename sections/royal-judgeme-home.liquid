{% comment %}
Royal • Avaliações (Home) — container para blocos do Judge.me
- Use somente na HOME para exibir Carousel/UGC de reviews com fotos
- Heading premium com gradiente Royal e opção de barra superior
- Integra com o snippet 'royal-overlap' para colar na seção de cima (margem negativa)
{% endcomment %}

<section id="section-{{ section.id }}" class="royal-judgeme-home">
  {% render 'royal-overlap', id: section.id %}

  <style>
    #section-{{ section.id }}{
      --grad-a: {{ section.settings.grad_a | default: '#0E5CF2' }};
      --grad-b: {{ section.settings.grad_b | default: '#0A3BCF' }};
      --title-color: {{ section.settings.title_color | default: '#0E5CF2' }};
      padding: {{ section.settings.pad_y | default: 24 }}px 0;
      position: relative;
      z-index: 2;
    }
    #section-{{ section.id }} .page-width{
      max-width: var(--page-width, 1200px);
      margin: 0 auto;
      padding: 0 16px;
    }
    #section-{{ section.id }} .topbar{
      height: 4px;
      background: linear-gradient(90deg, var(--grad-a), var(--grad-b));
      border-radius: 999px;
      margin: 0 0 12px;
    }
    #section-{{ section.id }} .title{
      font-weight: 800;
      font-size: clamp(18px, 2.2vw, 26px);
      line-height: 1.2;
      margin: 0 0 8px;
      letter-spacing: .2px;
    }
    #section-{{ section.id }} .title.is-gradient{
      background: linear-gradient(90deg, var(--grad-a), var(--grad-b));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    #section-{{ section.id }} .title.is-solid{
      color: var(--title-color);
    }
    #section-{{ section.id }} .align-center{ text-align: center; }
    #section-{{ section.id }} .align-left{ text-align: left; }
  </style>

  <div class="page-width {% if section.settings.align_center %}align-center{% else %}align-left{% endif %}">
    {% if section.settings.show_topbar %}
      <div class="topbar" aria-hidden="true"></div>
    {% endif %}

    {% if section.settings.title != blank %}
      <h2 class="title {% if section.settings.title_style == 'gradient' %}is-gradient{% else %}is-solid{% endif %}">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    {%- comment -%}
      Adicione aqui, via editor do tema, o bloco do app:
      - "Judge.me Reviews Carousel", ou
      - "Judge.me UGC Media Grid"
    {%- endcomment -%}
    {% for block in section.blocks %}
      {% render block %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Royal • Avaliações (Home)",
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "Avaliações dos clientes" },
    { "type": "checkbox", "id": "show_topbar", "label": "Mostrar barra superior em gradiente", "default": true },
    {
      "type": "select",
      "id": "title_style",
      "label": "Estilo do título",
      "default": "gradient",
      "options": [
        { "value": "gradient", "label": "Texto com gradiente Royal" },
        { "value": "solid", "label": "Cor sólida" }
      ]
    },
    { "type": "color", "id": "title_color", "label": "Cor do título (quando sólido)", "default": "#0E5CF2" },
    { "type": "color", "id": "grad_a", "label": "Gradiente — cor inicial", "default": "#0E5CF2" },
    { "type": "color", "id": "grad_b", "label": "Gradiente — cor final", "default": "#0A3BCF" },
    { "type": "checkbox", "id": "align_center", "label": "Centralizar conteúdo", "default": true },
    { "type": "range", "id": "pad_y", "label": "Espaço vertical (px)", "min": 0, "max": 80, "step": 2, "default": 24 },

    { "type": "header", "content": "Sobreposição (colar na seção de cima)" },
    { "type": "range", "id": "overlap_px", "label": "Tamanho da sobreposição (px)", "min": 0, "max": 80, "step": 2, "default": 16 },
    { "type": "range", "id": "overlap_px_mobile", "label": "Sobreposição (px) — mobile", "min": 0, "max": 80, "step": 2, "default": 12 }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    { "name": "Royal • Avaliações (Home)" }
  ]
}
{% endschema %}
