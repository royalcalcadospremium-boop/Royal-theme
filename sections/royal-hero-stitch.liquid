{%- comment -%}
  ╔════════════════════════════════════════════════════════════════╗
  ║   ROYAL HERO PREMIUM — Inspirado no design Stitch             ║
  ║   Hero escuro com cabeçalho transparente, glow neon e cards   ║
  ╚════════════════════════════════════════════════════════════════╝
{%- endcomment -%}

{%- assign glow_color = section.settings.glow_color | default: '#ff0000' -%}
{%- assign glow_r = glow_color | color_extract: 'red' -%}
{%- assign glow_g = glow_color | color_extract: 'green' -%}
{%- assign glow_b = glow_color | color_extract: 'blue' -%}

{%- comment -%}--- GOOGLE FONTS ---{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- comment -%}--- HEADER TRANSPARENCY OVERRIDE ---{%- endcomment -%}
{%- if section.settings.transparent_header -%}
<style id="rhs-header-override">
  /* Posiciona o header como absolute para sobrepor a hero */
  .shopify-section__header {
    position: absolute !important;
    width: 100%;
    z-index: 100;
    top: 0;
    left: 0;
  }
  .shopify-section__header header.header {
    background: transparent !important;
    transition: background 0.4s ease;
  }
  .shopify-section__header .nav-bar {
    background: transparent !important;
  }
  .shopify-section__header .nav-bar__inner {
    background: transparent !important;
  }
  /* Esconde a barra colorida sobre a hero */
  .shopify-section__header ~ .container-fluid.color-line,
  .shopify-section__header .container-fluid.color-line {
    display: none !important;
  }
  /* Quando scrollar, header volta ao fundo sólido */
  .shopify-section__header.rhs-header-solid header.header {
    background: {{ settings.header_background | default: '#0a0a0f' }} !important;
    box-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .shopify-section__header.rhs-header-solid .nav-bar {
    background: {{ settings.header_background | default: '#0a0a0f' }} !important;
  }
  .shopify-section__header.rhs-header-solid .nav-bar__inner {
    background: {{ settings.header_background | default: '#0a0a0f' }} !important;
  }
</style>
{%- endif -%}

{%- comment -%}--- HERO HTML ---{%- endcomment -%}
<section
  class="rhs"
  id="royal-hero-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="royal-hero-stitch"
  style="
    --rhs-bg-1: {{ section.settings.bg_color_1 }};
    --rhs-bg-2: {{ section.settings.bg_color_2 }};
    --rhs-glow: {{ glow_color }};
    --rhs-glow-rgb: {{ glow_r }}, {{ glow_g }}, {{ glow_b }};
    --rhs-text: {{ section.settings.text_color }};
    --rhs-btn-bg: {{ section.settings.btn_color }};
    --rhs-btn-text: {{ section.settings.btn_text_color }};
    --rhs-badge-bg: {{ section.settings.badge_color }};
  "
>
  {%- comment -%}Background smoke/cloud texture{%- endcomment -%}
  <div class="rhs__bg-layer"></div>
  <div class="rhs__bg-smoke"></div>

  <div class="rhs__container">
    {%- comment -%}=== MAIN CONTENT: TEXT + IMAGE ==={%- endcomment -%}
    <div class="rhs__content">

      {%- comment -%}--- LEFT: TEXT COLUMN ---{%- endcomment -%}
      <div class="rhs__text">
        {%- if section.settings.subtitle_top != blank -%}
          <span class="rhs__label">{{ section.settings.subtitle_top }}</span>
        {%- endif -%}

        <h2 class="rhs__title">
          {{ section.settings.title_line1 | default: 'AIR FORCE 1' }}<br>
          <span class="rhs__title-accent">{{ section.settings.title_line2 | default: 'CUSTOM' }}</span>
        </h2>

        {%- if section.settings.badge_text != blank -%}
          <span class="rhs__badge">{{ section.settings.badge_text }}</span>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="rhs__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <div class="rhs__cta-row">
          {%- if section.settings.cta_text != blank -%}
            <a href="{{ section.settings.cta_link | default: '#' }}" class="rhs__btn">
              {{ section.settings.cta_text }}
            </a>
          {%- endif -%}

          {%- if section.settings.price_text != blank -%}
            <span class="rhs__price">{{ section.settings.price_text }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%}--- RIGHT: PRODUCT IMAGE + GLOW ---{%- endcomment -%}
      <div class="rhs__visual">
        <div class="rhs__image-wrapper">
          {%- comment -%}Neon glow orbits{%- endcomment -%}
          <div class="rhs__orbit rhs__orbit--1"></div>
          <div class="rhs__orbit rhs__orbit--2"></div>
          <div class="rhs__orbit rhs__orbit--3"></div>

          {%- comment -%}Ground reflection glow{%- endcomment -%}
          <div class="rhs__glow-floor"></div>

          {%- comment -%}Product image{%- endcomment -%}
          {%- if section.settings.product_image != blank -%}
            <img
              class="rhs__product-img lazyload"
              src="{{ section.settings.product_image | img_url: '800x' }}"
              alt="{{ section.settings.title_line1 }} {{ section.settings.title_line2 }}"
              width="600"
              height="400"
              loading="eager"
            >
          {%- else -%}
            <div class="rhs__placeholder-img">
              <svg viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="100" height="80" rx="8" fill="rgba(255,255,255,0.05)"/>
                <text x="50" y="45" text-anchor="middle" fill="rgba(255,255,255,0.2)" font-size="8" font-family="sans-serif">Imagem do Produto</text>
              </svg>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- comment -%}=== BOTTOM CARDS ==={%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="rhs__cards">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'feature' -%}
              <div class="rhs__feature-card" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_image != blank -%}
                  <div class="rhs__feature-icon">
                    <img src="{{ block.settings.icon_image | img_url: '80x' }}" alt="{{ block.settings.title }}" loading="lazy">
                  </div>
                {%- elsif block.settings.fa_icon != blank -%}
                  <div class="rhs__feature-icon">
                    <i class="fa {{ block.settings.fa_icon }}"></i>
                  </div>
                {%- endif -%}
                <div class="rhs__feature-info">
                  <h4 class="rhs__feature-title">{{ block.settings.title }}</h4>
                  {%- if block.settings.description != blank -%}
                    <p class="rhs__feature-desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'product_card' -%}
              <a href="{{ block.settings.link | default: '#' }}" class="rhs__product-card" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  <div class="rhs__card-thumb">
                    <img src="{{ block.settings.image | img_url: '200x200', crop: 'center' }}" alt="{{ block.settings.name }}" loading="lazy">
                  </div>
                {%- endif -%}
                <div class="rhs__card-info">
                  <span class="rhs__card-name">{{ block.settings.name }}</span>
                  {%- if block.settings.subtitle_card != blank -%}
                    <span class="rhs__card-sub">{{ block.settings.subtitle_card }}</span>
                  {%- endif -%}
                  {%- if block.settings.price != blank -%}
                    <span class="rhs__card-price">{{ block.settings.price }}</span>
                  {%- endif -%}
                  {%- if block.settings.show_stars -%}
                    <div class="rhs__card-stars">
                      {%- for i in (1..5) -%}
                        {%- if i <= block.settings.star_count -%}★{%- else -%}☆{%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              </a>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%}=== COMPLETE CSS ==={%- endcomment -%}
<style>
  /* ╔══════════════════════════════════════╗
     ║   ROYAL HERO STITCH — STYLES        ║
     ╚══════════════════════════════════════╝ */

  /* --- SECTION CONTAINER --- */
  .rhs {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.hero_height_desktop }}px;
    overflow: hidden;
    display: flex;
    align-items: center;
    color: var(--rhs-text, #ffffff);
    font-family: 'Space Grotesk', sans-serif;
  }

  /* --- BACKGROUND LAYERS --- */
  .rhs__bg-layer {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--rhs-bg-1, #0a0a0f) 0%, var(--rhs-bg-2, #1a1a2e) 50%, #0d0d15 100%);
    z-index: 0;
  }

  .rhs__bg-smoke {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 60% 50% at 70% 50%, rgba(var(--rhs-glow-rgb), 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 80% 60% at 80% 80%, rgba(100, 120, 180, 0.04) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 30% 30%, rgba(255, 255, 255, 0.02) 0%, transparent 50%);
    pointer-events: none;
  }

  /* --- CONTAINER --- */
  .rhs__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1340px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top | default: 120 }}px 40px 40px;
  }

  /* --- MAIN CONTENT GRID --- */
  .rhs__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    min-height: calc({{ section.settings.hero_height_desktop }}px - 200px);
  }

  /* ═══ LEFT: TEXT COLUMN ═══ */
  .rhs__text {
    display: flex;
    flex-direction: column;
    gap: 8px;
    animation: rhs-fadeInLeft 0.8s ease-out both;
  }

  .rhs__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 6px;
  }

  .rhs__title {
    font-family: 'Anton', 'Impact', sans-serif;
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--rhs-text, #fff);
    margin: 0;
    text-shadow: 0 2px 30px rgba(0,0,0,0.3);
  }

  .rhs__title-accent {
    color: var(--rhs-text, #fff);
  }

  .rhs__badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 4px 14px;
    background: var(--rhs-badge-bg, #ff0000);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 4px;
    margin-top: 4px;
  }

  .rhs__subtitle {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.7);
    margin: 8px 0 0;
    line-height: 1.5;
    max-width: 340px;
  }

  .rhs__cta-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 20px;
  }

  .rhs__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 32px;
    background: var(--rhs-btn-bg, #ff0000);
    color: var(--rhs-btn-text, #fff);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow:
      0 4px 15px rgba(var(--rhs-glow-rgb), 0.3),
      0 0 40px rgba(var(--rhs-glow-rgb), 0.15);
  }

  .rhs__btn:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow:
      0 6px 25px rgba(var(--rhs-glow-rgb), 0.5),
      0 0 60px rgba(var(--rhs-glow-rgb), 0.25);
    color: var(--rhs-btn-text, #fff);
    text-decoration: none;
  }

  .rhs__btn::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 30%,
      rgba(255,255,255,0.12) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }

  .rhs__btn:hover::before {
    transform: translateX(100%);
  }

  .rhs__price {
    font-family: 'Anton', sans-serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--rhs-text, #fff);
    letter-spacing: 0.02em;
  }

  /* ═══ RIGHT: VISUAL COLUMN ═══ */
  .rhs__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: rhs-fadeInRight 0.8s 0.2s ease-out both;
  }

  .rhs__image-wrapper {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 3/2;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 800px;
  }

  .rhs__product-img {
    position: relative;
    z-index: 5;
    width: 100%;
    height: auto;
    max-width: 520px;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.4));
    transform: rotate(-5deg);
    transition: transform 0.6s ease;
  }

  .rhs__image-wrapper:hover .rhs__product-img {
    transform: rotate(-2deg) scale(1.04);
  }

  .rhs__placeholder-img {
    width: 100%;
    max-width: 400px;
    opacity: 0.5;
  }
  .rhs__placeholder-img svg {
    width: 100%;
    height: auto;
  }

  /* ═══ NEON ORBITS ═══ */
  .rhs__orbit {
    position: absolute;
    border-radius: 50%;
    border: 2px solid transparent;
    z-index: 4;
    pointer-events: none;
    filter: blur(1px);
  }

  .rhs__orbit--1 {
    width: 105%;
    height: 70%;
    top: 15%;
    left: -2.5%;
    border-image: linear-gradient(
      90deg,
      rgba(var(--rhs-glow-rgb), 0.8),
      transparent 40%,
      transparent 60%,
      rgba(var(--rhs-glow-rgb), 0.4)
    ) 1;
    border-radius: 50%;
    border-style: solid;
    border-width: 2px;
    border-color: rgba(var(--rhs-glow-rgb), 0.6) transparent transparent transparent;
    box-shadow:
      0 0 15px rgba(var(--rhs-glow-rgb), 0.3),
      inset 0 0 15px rgba(var(--rhs-glow-rgb), 0.05);
    transform: rotateX(65deg) rotateZ(0deg);
    animation: rhs-orbit-spin 5s linear infinite;
  }

  .rhs__orbit--2 {
    width: 95%;
    height: 65%;
    top: 18%;
    left: 2.5%;
    border-style: solid;
    border-width: 2px;
    border-color: transparent rgba(var(--rhs-glow-rgb), 0.5) transparent transparent;
    box-shadow:
      0 0 12px rgba(var(--rhs-glow-rgb), 0.2);
    transform: rotateX(65deg) rotateZ(120deg);
    animation: rhs-orbit-spin 5s linear infinite;
    animation-delay: -1.7s;
  }

  .rhs__orbit--3 {
    width: 110%;
    height: 75%;
    top: 12%;
    left: -5%;
    border-style: solid;
    border-width: 1.5px;
    border-color: transparent transparent rgba(var(--rhs-glow-rgb), 0.35) transparent;
    box-shadow:
      0 0 8px rgba(var(--rhs-glow-rgb), 0.15);
    transform: rotateX(65deg) rotateZ(240deg);
    animation: rhs-orbit-spin 7s linear infinite;
    animation-delay: -3s;
  }

  @keyframes rhs-orbit-spin {
    from { transform: rotateX(65deg) rotateZ(0deg); }
    to   { transform: rotateX(65deg) rotateZ(360deg); }
  }

  /* ═══ GROUND GLOW REFLECTION ═══ */
  .rhs__glow-floor {
    position: absolute;
    bottom: -15%;
    left: 10%;
    width: 80%;
    height: 40%;
    background: radial-gradient(
      ellipse at center,
      rgba(var(--rhs-glow-rgb), 0.25) 0%,
      rgba(var(--rhs-glow-rgb), 0.08) 40%,
      transparent 70%
    );
    filter: blur(20px);
    z-index: 3;
    pointer-events: none;
    animation: rhs-glow-pulse 3s ease-in-out infinite alternate;
  }

  @keyframes rhs-glow-pulse {
    0%   { opacity: 0.6; transform: scaleX(0.95); }
    100% { opacity: 1;   transform: scaleX(1.05); }
  }

  /* ═══ BOTTOM CARDS ═══ */
  .rhs__cards {
    display: flex;
    gap: 16px;
    margin-top: 30px;
    animation: rhs-fadeInUp 0.8s 0.5s ease-out both;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 10px;
  }
  .rhs__cards::-webkit-scrollbar { display: none; }

  /* --- Feature Card --- */
  .rhs__feature-card {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 220px;
    padding: 16px 20px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .rhs__feature-card:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(var(--rhs-glow-rgb), 0.3);
    transform: translateY(-2px);
  }

  .rhs__feature-icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(var(--rhs-glow-rgb), 0.12);
    color: var(--rhs-glow);
    font-size: 1rem;
  }
  .rhs__feature-icon img {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .rhs__feature-info {
    flex: 1;
    min-width: 0;
  }

  .rhs__feature-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rhs__feature-desc {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.45);
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* --- Product Card --- */
  .rhs__product-card {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 240px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    color: #fff;
    transition: background 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .rhs__product-card:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(var(--rhs-glow-rgb), 0.25);
    transform: translateY(-2px);
    text-decoration: none;
    color: #fff;
  }

  .rhs__card-thumb {
    flex-shrink: 0;
    width: 65px;
    height: 65px;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.06);
  }
  .rhs__card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .rhs__card-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .rhs__card-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rhs__card-sub {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
  }

  .rhs__card-price {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
  }

  .rhs__card-stars {
    font-size: 0.65rem;
    color: #f5c518;
    letter-spacing: 1px;
    margin-top: 2px;
  }

  /* ═══ ANIMATIONS ═══ */
  @keyframes rhs-fadeInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes rhs-fadeInRight {
    from { opacity: 0; transform: translateX(40px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes rhs-fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════
     RESPONSIVE — TABLET
     ═══════════════════════════════════════ */
  @media screen and (max-width: 999px) {
    .rhs {
      min-height: {{ section.settings.hero_height_mobile }}px;
    }

    .rhs__container {
      padding: 100px 24px 30px;
    }

    .rhs__content {
      grid-template-columns: 1fr;
      gap: 20px;
      text-align: center;
      min-height: auto;
    }

    .rhs__text {
      align-items: center;
      order: 1;
    }

    .rhs__visual {
      order: 2;
    }

    .rhs__title {
      font-size: clamp(2.2rem, 8vw, 3.2rem);
    }

    .rhs__subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .rhs__cta-row {
      justify-content: center;
      flex-wrap: wrap;
    }

    .rhs__badge {
      align-self: center;
    }

    .rhs__image-wrapper {
      max-width: 380px;
      margin: 0 auto;
    }

    .rhs__cards {
      gap: 12px;
    }

    .rhs__feature-card,
    .rhs__product-card {
      min-width: 200px;
    }
  }

  /* ═══════════════════════════════════════
     RESPONSIVE — MOBILE
     ═══════════════════════════════════════ */
  @media screen and (max-width: 640px) {
    .rhs {
      min-height: {{ section.settings.hero_height_mobile }}px;
    }

    .rhs__container {
      padding: 90px 16px 24px;
    }

    .rhs__title {
      font-size: clamp(2rem, 10vw, 2.8rem);
    }

    .rhs__subtitle {
      font-size: 0.88rem;
    }

    .rhs__btn {
      width: 100%;
      max-width: 280px;
      padding: 14px 28px;
      font-size: 0.82rem;
    }

    .rhs__price {
      font-size: 1.3rem;
    }

    .rhs__image-wrapper {
      max-width: 300px;
    }

    .rhs__product-img {
      transform: rotate(-3deg);
    }

    .rhs__orbit--1,
    .rhs__orbit--2,
    .rhs__orbit--3 {
      border-width: 1.5px;
    }

    .rhs__cards {
      flex-direction: row;
      gap: 10px;
      margin-top: 20px;
    }

    .rhs__feature-card {
      min-width: 180px;
      padding: 12px 14px;
    }

    .rhs__product-card {
      min-width: 200px;
      padding: 10px 12px;
    }

    .rhs__card-thumb {
      width: 55px;
      height: 55px;
    }
  }

  /* ═══ REDUZIR MOTION PARA ACESSIBILIDADE ═══ */
  @media (prefers-reduced-motion: reduce) {
    .rhs__orbit--1,
    .rhs__orbit--2,
    .rhs__orbit--3,
    .rhs__glow-floor {
      animation: none !important;
    }
    .rhs__text,
    .rhs__visual,
    .rhs__cards {
      animation: none !important;
    }
  }
</style>

{%- comment -%}=== JAVASCRIPT ==={%- endcomment -%}
{%- if section.settings.transparent_header -%}
<script>
(function() {
  var heroSection = document.getElementById('royal-hero-{{ section.id }}');
  var headerSection = document.querySelector('.shopify-section__header');
  if (!heroSection || !headerSection) return;

  /* Adiciona classe de transparência inicial */
  headerSection.classList.add('rhs-header-transparent');

  /* IntersectionObserver: detecta quando a hero sai da viewport */
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && entry.intersectionRatio > 0.1) {
          headerSection.classList.remove('rhs-header-solid');
        } else {
          headerSection.classList.add('rhs-header-solid');
        }
      });
    }, {
      threshold: [0, 0.1, 0.3]
    });
    observer.observe(heroSection);
  } else {
    /* Fallback: scroll listener */
    window.addEventListener('scroll', function() {
      var rect = heroSection.getBoundingClientRect();
      if (rect.bottom > 80) {
        headerSection.classList.remove('rhs-header-solid');
      } else {
        headerSection.classList.add('rhs-header-solid');
      }
    }, { passive: true });
  }
})();
</script>
{%- endif -%}

