<section class="section" data-section-id="{{ section.id }}" data-section-type="html">
  {% render 'royal-overlap', id: section.id %}

  <div class="container">
    {%- if section.settings.title != blank -%}
      <header class="section__header">
        <h2 class="section__title heading h3">{{ section.settings.title | escape }}</h2>
      </header>
    {%- endif -%}

    <div class="html rte">
      {{ section.settings.html }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom HTML",
  "settings": [

  {
    "type": "range",
    "id": "overlap_px",
    "label": "Tamanho da sobreposição (px)",
    "min": 0,
    "max": 80,
    "step": 2,
    "default": 0
  },
  {
    "type": "range",
    "id": "overlap_px_mobile",
    "label": "Tamanho da sobreposição (px) — mobile",
    "min": 0,
    "max": 80,
    "step": 2,
    "default": 0
  }
,
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your title"
    },
    {
      "type": "html",
      "id": "html",
      "label": "HTML",
      "default": "<p>Write or copy/paste HTML code</p>"
    }
  ],
  "presets": [
    {
      "category": "Advanced",
      "name": "Custom HTML"
    }
  ]
}
{% endschema %}