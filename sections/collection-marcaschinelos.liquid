<section class="section" id="section-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="collection-list">
  {% render 'royal-overlap', id: section.id %}

  <div class="container">
    {%- if section.settings.title != blank -%}
      <header class="section__header">
        <h2 class="section__title heading h3">{{ section.settings.title | escape }}</h2>

        {%- if section.settings.link_title != blank and section.settings.link != blank -%}
          <a href="{{ section.settings.link }}" class="section__action-link link">
            {{ section.settings.link_title | escape }} {% render 'icon', icon: 'tail-right' %}
          </a>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="scroller" data-cards="{{ section.settings.cards_per_row }}">
      <!-- Setas (desktop) -->
      <button class="scroller__arrow scroller__arrow--prev" aria-label="Anterior" type="button">
        {% render 'icon', icon: 'chevron-left' %}
      </button>
      <button class="scroller__arrow scroller__arrow--next" aria-label="Próximo" type="button">
        {% render 'icon', icon: 'chevron-right' %}
      </button>

      <div class="scroller__viewport">
        <div class="scroller__inner">
          <div class="collection-list">
            {%- for block in section.blocks -%}
              {%- assign collection = collections[block.settings.collection] -%}
              <a href="{{ collection.url | default: '#' }}"
                 class="collection-item"
                 data-collection-index="{{ forloop.index0 }}"
                 {{ block.shopify_attributes }}>
                {%- unless collection.empty? -%}
                  {%- assign collection_image = block.settings.image | default: collection.image | default: collection.products.first.featured_image -%}
                  <div class="collection-item__image-wrapper {% if section.settings.round_images %}collection-item__image-wrapper--rounded{% endif %}"
                       style="background: var(--background)!important; padding: 1.5px; background-image: url({{ collection_image | img_url: '1x1' }})">
                    {%- capture supported_sizes -%}{%- render 'image-size', sizes: '300,400,500,600,700,800', image: collection_image -%}{%- endcapture -%}
                    {%- assign image_url = collection_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                    <div class="aspect-ratio" style="padding-bottom: 100%">
                      <img class="lazyload image--fade-in"
                           data-src="{{ image_url }}"
                           data-widths="[{{ supported_sizes }}]"
                           data-sizes="auto"
                           alt="{{ collection_image.alt | escape }}">
                      <noscript><img src="{{ collection_image | img_url: '450x' }}" alt="{{ collection_image.alt | escape }}"></noscript>
                    </div>
                  </div>
                  {%- if section.settings.show_collection_title -%}
                    <span class="collection-item__title text--strong">
                      {{ collection.title }} {% render 'icon', icon: 'tail-right' %}
                    </span>
                  {%- endif -%}
                {%- else -%}
                  <div class="collection-item__image-wrapper {% if section.settings.round_images %}collection-item__image-wrapper--rounded{% endif %}">
                    {%- capture placeholder -%}{% cycle 'collection-1','collection-2','collection-3','collection-4','collection-5','collection-6' %}{%- endcapture -%}
                    {{- placeholder | placeholder_svg_tag: 'placeholder-svg' -}}
                  </div>
                  {%- if section.settings.show_collection_title -%}
                    <span class="collection-item__title text--strong">
                      {{ 'home_page.onboarding.collection_title' | t }} {% render 'icon', icon: 'tail-right' %}
                    </span>
                  {%- endif -%}
                {%- endunless -%}
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- Mantido, porém escondido -->
      <div class="scroller__edge scroller__edge--right" aria-hidden="true"></div>
    </div>
  </div>

  <style>
    /* ===== Espaçamentos da seção ===== */
    #section-{{ section.id }}{ margin-top: {{ section.settings.space_top_px | default: 0 }}px; margin-bottom: {{ section.settings.space_bottom_px | default: 16 }}px; }
    #section-{{ section.id }} .section__header{ margin-bottom: {{ section.settings.header_gap_px | default: 12 }}px; }

    /* ===== Variáveis ===== */
    #section-{{ section.id }} .scroller{
      --cards: {{ section.settings.cards_per_row | default: 6 }};
      --cards-mobile: {{ section.settings.cards_per_row_mobile | default: 5 }};
      --gap: {{ section.settings.gap_px | default: 16 }}px;
      --gap-mobile: {{ section.settings.gap_px_mobile | default: 8 }}px;
      position: relative;
    }

    /* ===== Viewport ===== */
    #section-{{ section.id }} .scroller__viewport{ position: relative; overflow: hidden; }
    #section-{{ section.id }} .scroller__inner{ overflow: auto; scrollbar-width: none; -ms-overflow-style: none; }
    #section-{{ section.id }} .scroller__inner::-webkit-scrollbar{ display: none; }

    /* ===== Trilho ===== */
    #section-{{ section.id }} .collection-list{ display: flex; gap: var(--gap); will-change: transform; backface-visibility: hidden; transform: translateZ(0); padding-right: 56px; touch-action: pan-y; }

    /* ===== Card base ===== */
    #section-{{ section.id }} .collection-item{ --basis-desktop: calc((100% - (var(--cards) - 1)*var(--gap)) / var(--cards)); flex: 0 0 var(--basis-desktop); max-width: var(--basis-desktop); text-decoration: none; }

    /* Largura fixa opcional (desktop) */
    {% assign desktop_min = 120 %}
    {% if section.settings.card_width_px and section.settings.card_width_px >= desktop_min %}
    #section-{{ section.id }} .collection-item{ flex-basis: {{ section.settings.card_width_px }}px; max-width: {{ section.settings.card_width_px }}px; }
    {% endif %}

    /* ===== Setas (desktop) ===== */
    #section-{{ section.id }} .scroller__arrow{ position: absolute; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 999px; border: 0; display: grid; place-items: center; background: rgba(255,255,255,.96); box-shadow: 0 6px 20px rgba(0,0,0,.12); cursor: pointer; z-index: 3; transition: opacity .2s ease; }
    #section-{{ section.id }} .scroller__arrow--prev{ left: -8px; opacity: 0; pointer-events: none; }
    #section-{{ section.id }} .scroller__arrow--next{ right: -8px; }
    #section-{{ section.id }} .scroller__edge--right{ display: none !important; }

    /* ===== MOBILE ===== */
    @media (max-width: 767px){
      #section-{{ section.id }} .scroller__arrow{ display: none; }
      #section-{{ section.id }} .scroller__inner{ overflow: hidden; }
      #section-{{ section.id }} .collection-list{ gap: var(--gap-mobile); padding-right: 0; }
      #section-{{ section.id }} .collection-item{ --basis-mobile: calc((100% - (var(--cards-mobile) - 1)*var(--gap-mobile)) / var(--cards-mobile)); flex-basis: var(--basis-mobile); max-width: var(--basis-mobile); }
    }
  </style>

  <script>
    (function(){
      const root = document.getElementById('section-{{ section.id }}');
      if (!root) return;
      const viewport = root.querySelector('.scroller__inner');
      const track = root.querySelector('.collection-list');
      const prevBtn = root.querySelector('.scroller__arrow--prev');
      const nextBtn = root.querySelector('.scroller__arrow--next');
      const mqlMobile = window.matchMedia('(max-width: 767px)');
      const stepDesktop = Math.max(1, parseInt({{ section.settings.scroll_step_desktop | default: 6 | json }}, 10));

      function itemWidth(){
        const item = track.querySelector('.collection-item');
        const gap = parseFloat(getComputedStyle(track).gap) || 16;
        return (item ? item.getBoundingClientRect().width : 240) + gap;
      }
      function scrollByCards(dir, n){ viewport.scrollBy({ left: itemWidth() * n * dir, behavior: 'smooth' }); }
      function updateArrows(){
        if (mqlMobile.matches){ return; }
        const max = track.scrollWidth - viewport.clientWidth - 1;
        const showLeft = viewport.scrollLeft > 0;
        prevBtn.style.opacity = showLeft ? 1 : 0;
        prevBtn.style.pointerEvents = showLeft ? 'auto' : 'none';
        const hasOverflow = max > 0;
        nextBtn.style.opacity = hasOverflow ? 1 : 0;
        nextBtn.style.pointerEvents = hasOverflow ? 'auto' : 'none';
      }
      nextBtn?.addEventListener('click', ()=> scrollByCards(1, stepDesktop));
      prevBtn?.addEventListener('click', ()=> scrollByCards(-1, stepDesktop));
      viewport.addEventListener('scroll', updateArrows);
      window.addEventListener('resize', updateArrows);
      updateArrows();

      /* ===== Mobile: marquee contínuo + seek ===== */
      const enableMobileAuto = {{ section.settings.auto_play_mobile | default: true | json }};
      const speedM = parseFloat({{ section.settings.auto_speed_mobile | default: 50 | json }});
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let raf = null, last = 0, offset = 0, half = 0, paused = false, inView = true, cloned = false;
      let dragging = false, dragStartX = 0, dragStartOffset = 0;

      function duplicateIfNeeded(){ if (cloned || !track) return; const frag = document.createDocumentFragment(); Array.from(track.children).forEach(n=> frag.appendChild(n.cloneNode(true))); track.appendChild(frag); cloned = true; }
      function recalcHalf(){ half = track.scrollWidth / 2; }
      function applyTransform(){ track.style.transform = 'translateX(' + offset + 'px)'; }
      function wrapOffset(v){ if (half <= 0) return v; while (v <= -half) v += half; while (v > 0) v -= half; return v; }
      function frame(t){ if (!mqlMobile.matches || !enableMobileAuto || prefersReduced){ cancel(); return; } if (!last) last = t; const dt = (t - last)/1000; last = t; if (!paused && !dragging && inView && half > 0){ offset -= speedM * dt; offset = wrapOffset(offset); applyTransform(); } raf = requestAnimationFrame(frame); }
      function start(){ if (!raf) raf = requestAnimationFrame(frame); }
      function cancel(){ if (raf){ cancelAnimationFrame(raf); raf = null; } last = 0; }

      ['wheel','keydown'].forEach(eName=>{ viewport.addEventListener(eName, ()=>{ if (mqlMobile.matches) paused = true; }, {passive:true}); });
      window.addEventListener('blur', ()=>{ if (mqlMobile.matches) paused = true; }, {passive:true});

      function onPointerDown(clientX){ if (!mqlMobile.matches) return; dragging = true; paused = true; dragStartX = clientX; dragStartOffset = offset; }
      function onPointerMove(clientX, e){ if (!dragging) return; const dx = clientX - dragStartX; offset = wrapOffset(dragStartOffset + dx); applyTransform(); if (e && e.cancelable) e.preventDefault(); }
      function onPointerUp(){ if (!dragging) return; dragging = false; paused = false; }

      // Touch
      viewport.addEventListener('touchstart', e=>{ if (!e.touches || !e.touches[0]) return; onPointerDown(e.touches[0].clientX); }, {passive:true});
      viewport.addEventListener('touchmove', e=>{ if (!e.touches || !e.touches[0]) return; onPointerMove(e.touches[0].clientX, e); }, {passive:false});
      viewport.addEventListener('touchend', onPointerUp, {passive:true});
      viewport.addEventListener('touchcancel', onPointerUp, {passive:true});

      // Mouse (dev)
      viewport.addEventListener('mousedown', e=>{ onPointerDown(e.clientX); });
      window.addEventListener('mousemove', e=>{ onPointerMove(e.clientX, e); }, {passive:false});
      window.addEventListener('mouseup', onPointerUp);

      if ('IntersectionObserver' in window){ const io = new IntersectionObserver((entries)=>{ inView = entries[0]?.isIntersecting ?? true; }, { threshold: 0.1 }); io.observe(root); }

      function handleMode(){ if (mqlMobile.matches){ track.style.transform = 'translateX(0)'; offset = 0; if (!cloned) duplicateIfNeeded(); recalcHalf(); start(); } else { cancel(); track.style.transform = 'none'; } updateArrows(); }
      if ('ResizeObserver' in window){ const ro = new ResizeObserver(()=>{ if (mqlMobile.matches){ recalcHalf(); } updateArrows(); }); ro.observe(track); } else { window.addEventListener('resize', ()=>{ if (mqlMobile.matches){ recalcHalf(); } updateArrows(); }); }
      try{ mqlMobile.addEventListener('change', handleMode); }catch(e){ mqlMobile.addListener(handleMode); }
      handleMode();
    })();
  </script>

  <!-- =====================================================
       DUAL CTA (Dois botões nos cards de PRODUTO) — Global
       ===================================================== -->
  <style>
    /* Estilos base para todos os cards de PRODUTO (não afeta este carrossel de coleções) */
    :root{
      --gx-mini-bg:#fff; --gx-mini-text:#1f2937; --gx-mini-border:#e5e7eb;
      --gx-mini-bg-hover:#f3f4f6; --gx-mini-text-hover:#111827;
      --gx-gap:8px; --gx-buy-basis-d:78%; --gx-buy-basis-m:74%;
    }
    .gx-dual-cta{display:flex;align-items:stretch;gap:var(--gx-gap);width:100%;}
    .gx-dual-cta .gx-buy{flex:1 1 var(--gx-buy-basis-d);background:#00C65E!important;color:#fff!important;border-color:transparent!important;font-weight:600;}
    .gx-dual-cta .gx-buy:hover{background:#00A653!important;}
    .gx-addtocart-mini{flex:0 0 calc(100% - var(--gx-buy-basis-d));display:inline-flex;align-items:center;justify-content:center;padding:0 10px;border-radius:9999px;border:1px solid var(--gx-mini-border);background:var(--gx-mini-bg);color:var(--gx-mini-text);cursor:pointer;font-weight:600;transition:transform .06s ease,background .2s ease,color .2s ease,box-shadow .2s ease;min-height:44px;}
    .gx-addtocart-mini:hover{background:var(--gx-mini-bg-hover);color:var(--gx-mini-text-hover);} .gx-addtocart-mini svg{width:22px;height:22px;}
    @media(max-width:749px){ .gx-dual-cta .gx-buy{flex-basis:var(--gx-buy-basis-m);} .gx-addtocart-mini{flex-basis:calc(100% - var(--gx-buy-basis-m));min-height:42px;} }
    .gx-addtocart-mini.gx-added{ box-shadow:0 0 0 2px rgba(16,185,129,.25) inset; }
    .gx-addtocart-mini.gx-error{ box-shadow:0 0 0 2px rgba(239,68,68,.25) inset; }
  </style>

  <script>
  (function(){
    // Escopo global: roda na página inteira para pegar QUALQUER grid de produtos
    var root = document; // <- diferente do script original, aqui pegamos o documento inteiro

    function cartIcon(){
      var ns='http://www.w3.org/2000/svg';
      var svg=document.createElementNS(ns,'svg'); svg.setAttribute('viewBox','0 0 24 24'); svg.setAttribute('aria-hidden','true');
      var p=document.createElementNS(ns,'path');
      p.setAttribute('d','M7 4h-2l-1 2v2h2l3.6 7.59c.17.33.51.41.74.41h7.66a1 1 0 0 0 .95-.68l2-6A1 1 0 0 0 20 8H8.31l-.95-2H21V4H7zm3 15a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm8 0a2 2 0 1 0 .001 4.001A2 2 0 0 0 18 19z');
      svg.appendChild(p); return svg;
    }

    function getCard(el){ return el && (el.closest('.product-item, .product-card, .card--product, .grid__item, li, article') || null); }
    function getProductLink(scope){ return (scope || root).querySelector('a[href*="/products/"]:not([href*="#"])'); }

    function isIconOnlyButton(btn){
      if (!btn) return false;
      var hasSvg = !!btn.querySelector('svg');
      var txt = (btn.textContent || '').replace(/\s+/g,'').trim();
      var looksIconOnly = hasSvg && txt.length === 0;
      var iconClass = /\b(button--icon|product-card__icon|quick-add|icon-button)\b/.test(btn.className || '');
      return looksIconOnly || iconClass;
    }

    function openCartDrawer(){
      try { if (window.CartDrawer && typeof window.CartDrawer.refresh==='function') window.CartDrawer.refresh(); } catch(e){}
      try { if (window.CartDrawer && typeof window.CartDrawer.open==='function') { window.CartDrawer.open(); return; } } catch(e){}
      try { document.dispatchEvent(new CustomEvent('cart:refresh')); } catch(e){}
      try { document.dispatchEvent(new CustomEvent('cart:open')); } catch(e){}
      try { window.dispatchEvent(new CustomEvent('cart:open')); } catch(e){}
      try { document.dispatchEvent(new CustomEvent('theme:cart:open')); } catch(e){}
    }

    function findPrimaryCTA(card){
      if (!card) return null;
      var candidates = card.querySelectorAll('.product-card__cta .button, .product-item__cta .button, button[name="add"], button[type="submit"], .button[name="add"], a.button, button.button, .button--primary');
      var chosen = null;
      Array.prototype.some.call(candidates, function(btn){
        if (btn.closest('form[action*="/cart/add"]')) { chosen = btn; return true; }
        if (!isIconOnlyButton(btn)) { chosen = btn; return true; }
        return false;
      });
      if (!chosen) chosen = card.querySelector('a.button:not([href*="#"])');
      return chosen;
    }

    function patchForms(){
      var forms = root.querySelectorAll('form[action*="/cart/add"]:not(.gx-ready)');
      forms.forEach(function(form){
        var card = getCard(form); if (!card) return;
        var buy = findPrimaryCTA(card) || form.querySelector('button[name="add"], button[type="submit"], .button[name="add"]');
        if (!buy) { form.classList.add('gx-ready'); return; }
        if (isIconOnlyButton(buy)) { form.classList.add('gx-ready'); return; }
        if (buy.closest('.gx-dual-cta')) { form.classList.add('gx-ready'); return; }

        var row = document.createElement('div'); row.className = 'gx-dual-cta';
        buy.parentNode.insertBefore(row, buy); row.appendChild(buy);
        buy.classList.add('gx-buy'); buy.type = 'button';
        if (!buy.dataset.gxOriginalText) buy.dataset.gxOriginalText = (buy.textContent || '').trim();
        buy.addEventListener('click', function(){ var link = getProductLink(card); if (link && link.href) window.location.href = link.href; });

        var mini = document.createElement('button'); mini.type='button'; mini.className='gx-addtocart-mini'; mini.setAttribute('aria-label','Adicionar ao carrinho'); mini.appendChild(cartIcon()); row.appendChild(mini);
        mini.addEventListener('click', function(e){
          e.preventDefault(); e.stopPropagation();
          var idInput = form.querySelector('[name="id"]'); var id = idInput && idInput.value;
          var qtyInput = form.querySelector('[name="quantity"]'); var qty = qtyInput ? (parseInt(qtyInput.value,10) || 1) : 1;
          if (!id){ var link = getProductLink(card); if (link && link.href) window.location.href = link.href; return; }
          mini.disabled = true;
          fetch('/cart/add.js', { method:'POST', headers:{ 'Content-Type':'application/json','Accept':'application/json' }, body: JSON.stringify({ id:id, quantity:qty }) })
          .then(function(r){ if(!r.ok) throw 0; return r.json(); })
          .then(function(){ mini.classList.add('gx-added'); openCartDrawer(); })
          .catch(function(){ mini.classList.add('gx-error'); })
          .finally(function(){ setTimeout(function(){ mini.classList.remove('gx-added','gx-error'); mini.disabled=false; }, 1200); });
        });
        form.classList.add('gx-ready');
      });
    }

    function patchNoForm(){
      var btns = root.querySelectorAll('.product-card__cta .button, .product-item__cta .button, a.button, button.button, .button--primary');
      btns.forEach(function(btn){
        if (btn.dataset.gx === '1') return;
        if (btn.closest('form[action*="/cart/add"]')) return;
        var card = getCard(btn); if (!card) return;
        if (isIconOnlyButton(btn)) return;
        if (btn.closest('.gx-dual-cta')){ btn.dataset.gx = '1'; return; }
        var row = document.createElement('div'); row.className = 'gx-dual-cta'; btn.parentNode.insertBefore(row, btn); row.appendChild(btn);
        btn.classList.add('gx-buy'); btn.type = 'button';
        if (!btn.dataset.gxOriginalText) btn.dataset.gxOriginalText = (btn.textContent || '').trim();
        btn.addEventListener('click', function(){ var link = getProductLink(card); if (link && link.href) window.location.href = link.href; });
        var mini = document.createElement('button'); mini.type='button'; mini.className='gx-addtocart-mini'; mini.setAttribute('aria-label','Selecionar variação'); mini.appendChild(cartIcon()); row.appendChild(mini);
        mini.addEventListener('click', function(){ var link = getProductLink(card); if (link && link.href) window.location.href = link.href; });
        btn.dataset.gx = '1'; card.classList.add('gx-dualized');
      });
    }

    function patchAll(){ patchForms(); patchNoForm(); }
    patchAll();
    document.addEventListener('shopify:section:load', patchAll);
    ['collection:refresh','products:reloaded','ajax:loaded'].forEach(function(evt){ document.addEventListener(evt, patchAll); });
  })();
  </script>
</section>

{% schema %}
{
  "name": "Marcas Chinelos",
  "settings": [
    { "type": "range", "id": "overlap_px", "label": "Tamanho da sobreposição (px)", "min": 0, "max": 80, "step": 2, "default": 0 },
    { "type": "range", "id": "overlap_px_mobile", "label": "Tamanho da sobreposição (px) — mobile", "min": 0, "max": 80, "step": 2, "default": 0 },

    /* Desktop */
    { "type": "range", "id": "cards_per_row", "label": "Cards por tela (desktop)", "min": 2, "max": 12, "step": 1, "default": 6 },
    { "type": "range", "id": "scroll_step_desktop", "label": "Passo ao clicar na seta (desktop)", "min": 1, "max": 6, "step": 1, "default": 6 },

    /* Mobile */
    { "type": "range", "id": "cards_per_row_mobile", "label": "Cards por tela (mobile)", "min": 1, "max": 10, "step": 1, "default": 5 },
    { "type": "checkbox", "id": "auto_play_mobile", "label": "Auto-contínuo no mobile", "default": true },
    { "type": "range", "id": "auto_speed_mobile", "label": "Velocidade (px/seg) — mobile", "min": 20, "max": 200, "step": 5, "default": 50 },

    /* Visuais */
    { "type": "range", "id": "gap_px", "label": "Gap (desktop) px", "min": 0, "max": 40, "step": 1, "default": 16 },
    { "type": "range", "id": "gap_px_mobile", "label": "Gap (mobile) px", "min": 0, "max": 32, "step": 1, "default": 8 },
    { "type": "range", "id": "card_width_px", "label": "Largura fixa do card (px) — desktop (opcional)", "min": 120, "max": 480, "step": 4, "default": 120 },
    { "type": "range", "id": "card_width_px_mobile", "label": "Largura fixa do card (px) — mobile (opcional)", "min": 100, "max": 360, "step": 4, "default": 100 },

    { "type": "range", "id": "header_gap_px", "label": "Espaço abaixo do título (px)", "min": 0, "max": 40, "step": 1, "default": 12 },
    { "type": "range", "id": "space_top_px", "label": "Espaço acima da seção (px)", "min": 0, "max": 80, "step": 2, "default": 0 },
    { "type": "range", "id": "space_bottom_px", "label": "Espaço abaixo da seção (px)", "min": 0, "max": 80, "step": 2, "default": 16 },

    { "type": "text", "id": "title", "label": "Título da seção", "default": "Veja por Numeração" },
    { "type": "text", "id": "link_title", "label": "Título do link", "default": "Ver todas" },
    { "type": "url", "id": "link", "label": "Link", "default": "/collections" },
    { "type": "checkbox", "id": "round_images", "label": "Imagens redondas", "default": true },
    { "type": "checkbox", "id": "show_collection_title", "label": "Mostrar título das coleções", "default": true }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Imagem", "info": "600 x 600px .jpg recomendado" }
      ]
    }
  ],
  "presets": [
    { "category": "Collection", "name": "Marcas Chinelos", "blocks": [
      { "type": "collection" },{ "type": "collection" },{ "type": "collection" },{ "type": "collection" },{ "type": "collection" },{ "type": "collection" }
    ] }
  ]
}
{% endschema %}
