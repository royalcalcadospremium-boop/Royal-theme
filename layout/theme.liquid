{% section 'cart-drawer' %}

<script>
(function(){
  // ==== OPEN CART (ultra-compat) ====
  function openCartDrawer(payload){
    // 1) Eventos que muitos temas escutam
    try{ document.dispatchEvent(new CustomEvent('cart:refresh', {detail: payload})); }catch(e){}
    try{ document.dispatchEvent(new CustomEvent('cart:open',    {detail: payload})); }catch(e){}
    try{ document.dispatchEvent(new CustomEvent('added.ajaxCart', {detail: payload})); }catch(e){}
    try{ document.dispatchEvent(new CustomEvent('cart:updated', {detail: payload})); }catch(e){}

    // 2) Dawn / OS 2.0
    var dawnDrawer = document.querySelector('cart-drawer');
    if (dawnDrawer){
      try{ if (typeof dawnDrawer.open === 'function'){ dawnDrawer.open(); return; } }catch(e){}
      try{ dawnDrawer.setAttribute('open',''); return; }catch(e){}
    }
    var dawnNotif = document.querySelector('cart-notification');
    if (dawnNotif){
      try{ if (typeof dawnNotif.open === 'function'){ dawnNotif.open(); return; } }catch(e){}
    }

    // 3) APIs de temas conhecidos
    try{ if (window.cartDrawer && typeof window.cartDrawer.open === 'function'){ window.cartDrawer.open(); return; } }catch(e){}
    try{ if (window.theme && window.theme.Cart && typeof window.theme.Cart.open === 'function'){ window.theme.Cart.open(); return; } }catch(e){}
    try{ if (window.Shopify && window.Shopify.theme && window.Shopify.theme.cart && typeof window.Shopify.theme.cart.open === 'function'){ window.Shopify.theme.cart.open(); return; } }catch(e){}
    try{ if (window.PXUTheme && PXUTheme.jsDrawer && typeof PXUTheme.jsDrawer.open === 'function'){ PXUTheme.jsDrawer.open('CartDrawer'); return; } }catch(e){}
    try{ if (window.Minicart && typeof window.Minicart.open === 'function'){ window.Minicart.open(); return; } }catch(e){}
    try{ if (window.Drawer && typeof window.Drawer.open === 'function'){ window.Drawer.open('cart'); return; } }catch(e){}

    // 4) Clicar em possíveis gatilhos visíveis/ocultos
    var triggers = document.querySelectorAll([
      '[data-action="open-cart"]',
      '[data-cart-toggle]',
      '[data-drawer="cart"]',
      '[data-open="cart"]',
      '[data-drawer-target="cart"]',
      'button[aria-controls*="CartDrawer"]',
      'a[href="#CartDrawer"]',
      '[aria-controls="cart-drawer"]',
      '.header__cart', '.site-header__cart',
      '.js-mini-cart-toggle', '.minicart-toggle', '.open-cart'
    ].join(','));
    for (var i=0;i<triggers.length;i++){
      var el = triggers[i];
      try { el.click(); return; } catch(e){}
    }

    // 5) Forçar classes em drawers comuns já no DOM (sem mudar de página)
    var drawer = document.querySelector('[data-cart-drawer], #CartDrawer, .cart-drawer, .drawer--cart, .mini-cart, .minicart, #ajaxifyCart');
    if (drawer){
      try{
        drawer.classList.add('is-open','drawer--is-open','active','open');
        drawer.removeAttribute('aria-hidden');
        document.documentElement.classList.add('drawer-open','js-drawer-open','scroll-lock');
        document.body.classList.add('drawer-open','js-drawer-open','no-scroll');
        return;
      }catch(e){}
    }
  }
  window.openCartDrawer = openCartDrawer;

  // Garante que qualquer .gx-addtocart-mini tente abrir o drawer
  document.addEventListener('click', function(ev){
    var btn = ev.target && ev.target.closest && ev.target.closest('.gx-addtocart-mini');
    if (!btn) return;
    // dá um pequeno intervalo caso o tema atualize o DOM do carrinho
    setTimeout(function(){ openCartDrawer(); }, 30);
  }, true);
})();
</script>

<script>
(function(){
  // Captura cliques no botão do mini-cart
  document.addEventListener('click', function(e){
    var btn = e.target && e.target.closest ? e.target.closest('[data-royal-open-cart]') : null;
    if(!btn) return;

    e.preventDefault();
    e.stopPropagation();

    // Abre seu drawer Royal (da seção RoyalCartDrawer)
    if (window.RoyalCartDrawer && typeof window.RoyalCartDrawer.open === 'function') {
      window.RoyalCartDrawer.open();
      return;
    }

    // Fallback seguro
    window.location.href = '/checkout';
  }, true);
})();
</script>

