<!-- Troca "em até 12x ..." por "ou 12x ..." em todo o site -->
<script>
(function () {
  // padrões que cobrimos (maiúsculas/minúsculas e acentos):
  // "em até 12x de R$ ..."  -> "ou 12x de R$ ..."
  // "em até 12x"            -> "ou 12x"
  const patterns = [
    { re: /\bem\s*at[eé]\s*(\d+)\s*[xX]\s*de\b/gi, repl: 'ou $1x de' },
    { re: /\bem\s*at[eé]\s*(\d+)\s*[xX]\b/gi, repl: 'ou $1x' }
  ];
  const SKIP = /^(SCRIPT|STYLE|NOSCRIPT|TEXTAREA|INPUT|OPTION)$/i;

  function replaceTextNode(node){
    if (node.nodeType !== Node.TEXT_NODE) return;
    const p = node.parentNode;
    if (!p || SKIP.test(p.nodeName)) return;

    let text = node.nodeValue, changed = false;
    for (const {re, repl} of patterns){
      const t2 = text.replace(re, repl);
      if (t2 !== text){ text = t2; changed = true; }
    }
    if (changed) node.nodeValue = text;
  }

  function walk(root){
    try{
      const tw = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);
      let n; while ((n = tw.nextNode())) replaceTextNode(n);
    } catch(e){/* noop */}
  }

  function init(){
    walk(document.body);
    new MutationObserver(muts => {
      for (const m of muts) {
        if (m.addedNodes) m.addedNodes.forEach(node => walk(node));
      }
    }).observe(document.body, { childList:true, subtree:true });
  }

  if (document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

