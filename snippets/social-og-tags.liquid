{%- liquid
  assign fallback_image = settings.social_sharing_image | default: settings.logo | default: settings.header_logo

  assign og_type  = 'website'
  assign og_title = shop.name
  assign og_desc  = shop.meta_description | default: shop.name
  assign og_url   = canonical_url | default: request.origin
  assign og_image = nil

  if template contains 'product'
    assign og_type  = 'product'
    assign og_title = product.title | append: ' – ' | append: shop.name
    assign og_desc  = product.description | strip_html | truncate: 160
    assign og_url   = shop.url | append: product.url
    if product.featured_image
      assign og_image = product.featured_image | img_url: '1200x630', crop: 'center', format: 'pjpg'
    endif

  elsif template contains 'collection'
    assign og_type  = 'website'
    assign og_title = collection.title | append: ' – ' | append: shop.name
    assign og_desc  = collection.description | strip_html | truncate: 160
    assign og_url   = shop.url | append: collection.url
    if collection.image
      assign og_image = collection.image | img_url: '1200x630', crop: 'center', format: 'pjpg'
    endif

  elsif template contains 'page'
    assign og_type  = 'website'
    assign og_title = page.title | append: ' – ' | append: shop.name
    assign og_desc  = page.content | strip_html | truncate: 160
    assign og_url   = shop.url | append: page.url
  endif

  if og_image == nil and fallback_image
    assign og_image = fallback_image | img_url: '1200x630', crop: 'center', format: 'pjpg'
  endif
-%}

<!-- Open Graph -->
<meta property="og:site_name" content="{{ shop.name }}" />
<meta property="og:type" content="{{ og_type }}" />
<meta property="og:title" content="{{ og_title }}" />
<meta property="og:description" content="{{ og_desc }}" />
<meta property="og:url" content="{{ og_url }}" />
{%- if og_image -%}
  <meta property="og:image" content="{{ og_image | prepend: 'https:' }}" />
  <meta property="og:image:secure_url" content="{{ og_image | prepend: 'https:' }}" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
{%- endif -%}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ og_title }}" />
<meta name="twitter:description" content="{{ og_desc }}" />
{%- if og_image -%}
  <meta name="twitter:image" content="{{ og_image | prepend: 'https:' }}" />
{%- endif -%}
