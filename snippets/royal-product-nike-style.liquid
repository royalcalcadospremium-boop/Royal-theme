  }

  [data-section-type="product"] .product-block-list__item--trust {
    order: 7 !important;
  }

  [data-section-type="product"] .product-block-list__item--shipping {
    order: 8 !important;
  }

  [data-section-type="product"] .product-meta__title {
    font-size: 24px !important;
    line-height: 1.3 !important;
  }

  [data-section-type="product"] .block-swatch-list {
    grid-template-columns: repeat(5, 1fr) !important;
    gap: 6px !important;
  }

  [data-section-type="product"] .block-swatch__item {
    min-height: 44px !important;
    font-size: 14px !important;
    padding: 6px 8px !important;
  }

  [data-section-type="product"] .product-form__add-button {
    height: 52px !important;
    line-height: 52px !important;
    font-size: 15px !important;
  }

  [data-section-type="product"] .product-block-list__item--description,
  [data-section-type="product"] .product-block-list__item--reviews,
  [data-section-type="product"] .product-block-list__item--trust,
  [data-section-type="product"] .product-block-list__item--shipping,
  [data-section-type="product"] .product-block-list__item--content {
    padding: 0 16px !important;
  }

