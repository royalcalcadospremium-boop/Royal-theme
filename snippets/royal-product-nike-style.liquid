═══════════════════════════════════════════════════════════
  JAVASCRIPT: Esconde o botão flutuante quando o botão
  raiz do produto está visível na tela.
═══════════════════════════════════════════════════════════
{%- endcomment -%}
<script>
(function(){
  'use strict';

  function initFloatingToggle() {
    var floatingBar = document.getElementById('scrollToTop');
    if (!floatingBar) return;

    // Encontra o botão raiz do produto (o ATC principal)
    var mainBtn = document.querySelector('[data-section-type="product"] .product-form__add-button');
    if (!mainBtn) return;

    // IntersectionObserver: observa se o botão raiz está visível
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          // Botão raiz VISÍVEL → esconde o flutuante
          floatingBar.classList.add('is-hidden');
        } else {
          // Botão raiz FORA DA TELA → mostra o flutuante
          floatingBar.classList.remove('is-hidden');
        }
      });
    }, {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    });

    observer.observe(mainBtn);
  }

  // Executa quando o DOM estiver pronto
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(initFloatingToggle, 500);
    });
  } else {
    setTimeout(initFloatingToggle, 500);
  }

  // Suporte a Shopify section reload
  document.addEventListener('shopify:section:load', function() {
    setTimeout(initFloatingToggle, 500);
  });
})();
</script>
