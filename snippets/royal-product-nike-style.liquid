<script>
(function(){
  'use strict';

  // ─── 1. Esconder botão flutuante quando raiz está visível ───
  function initFloatingToggle() {
    var floatingBar = document.getElementById('scrollToTop');
    if (!floatingBar) return;

    var mainBtn = document.querySelector('[data-section-type="product"] .product-form__add-button');
    if (!mainBtn) return;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          floatingBar.classList.add('is-hidden');
        } else {
          floatingBar.classList.remove('is-hidden');
        }
      });
    }, { root: null, rootMargin: '0px', threshold: 0.1 });

    observer.observe(mainBtn);
  }

  // ─── 2. Mobile: mover variantes/botão para abaixo da galeria ───
  function moveVariantsBelowGallery() {
    if (window.innerWidth > 999) return;

    var section = document.querySelector('[data-section-type="product"]');
    if (!section) return;

    var wrapper = section.querySelector('.product-block-list__wrapper');
    if (!wrapper) return;

    // Evita executar mais de uma vez
    if (document.getElementById('royal-variants-below-gallery')) return;

    var variants = section.querySelector('.product-form__variants');
    var paymentContainer = section.querySelector('.product-form__payment-container');

    if (!variants && !paymentContainer) return;

    // Cria container novo
    var container = document.createElement('div');
    container.id = 'royal-variants-below-gallery';

    // Move os elementos (não clona — move de verdade)
    if (variants) {
      variants.parentNode.querySelector('.product-form__variants') && container.appendChild(variants);
    }
    if (paymentContainer) {
      container.appendChild(paymentContainer);
    }

    // Insere no wrapper
    wrapper.appendChild(container);
  }

  // ─── 3. Esconder "pessoas vendo" via JS (fallback) ───
  function hideViewerCount() {
    var olhos = document.querySelectorAll('[data-section-type="product"] .olho');
    olhos.forEach(function(el) {
      var parent = el.closest('div[style*="display: flex"]');
      if (parent) parent.style.display = 'none';
    });
  }

  // ─── INIT ───
  function init() {
    setTimeout(function() {
      initFloatingToggle();
      moveVariantsBelowGallery();
      hideViewerCount();
    }, 300);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', init);
})();
</script>
