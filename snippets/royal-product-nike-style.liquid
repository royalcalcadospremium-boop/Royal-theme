/* ═══════════════════════════════════════════════════════
   18. TRANSIÇÕES
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .block-swatch__item,
[data-section-type="product"] .color-swatch__item,
[data-section-type="product"] .variant-swatch__item,
[data-section-type="product"] .product-form__add-button,
.botaoflutuante #clicar {
  transition: all 0.15s ease !important;
