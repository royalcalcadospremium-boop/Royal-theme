{%- comment -%}
  ROYAL PRODUCT — ESTILO NIKE v4.0
  Layout idêntico ao Nike.com.br mobile
{%- endcomment -%}

<style>
/* ═══════════════════════════════════════════════════════
   1. RESET
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"],
[data-section-type="product"] .container {
  background: #ffffff !important;
  max-width: 100% !important;
}

[data-section-type="product"] .card {
  border: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
  background: transparent !important;
}

[data-section-type="product"] .card__separator {
  display: none !important;
}

[data-section-type="product"] .container--flush {
  padding: 0 !important;
}

/* ═══════════════════════════════════════════════════════
   2. ESCONDER ELEMENTOS
   ═══════════════════════════════════════════════════════ */

/* WhatsApp Share */
.rc-badge-slot, .rc-after-title, .rc-share-badge,
[data-section-type="product"] .product-meta__share-buttons,
#rc-whats-anchor, #rc-whats-anchor + .rc-badge-slot {
  display: none !important;
}

/* Parcelas "ou 12x de R$..." */
[data-section-type="product"] .product-form__info-content > p[style*="font-size:16px"],
[data-section-type="product"] .product-form__info-content > p[style*="font-size: 16px"] {
  display: none !important;
}

/* Label "R$ X de desconto" */
[data-section-type="product"] .product-meta__label-list {
  display: none !important;
}

/* Botão "Adicionar ao carrinho" extra */
[data-section-type="product"] .button--primary-add {
  display: none !important;
}

/* PIX badge "Até 10% OFF no PIX" */
[data-section-type="product"] .product-form__info-content > span[style*="border-radius: 21px"] {
  display: none !important;
}

/* "XX pessoas estão vendo esse produto" + olho */
[data-section-type="product"] div:has(> .olho) {
  display: none !important;
}

/* Quantidade selector +1- */
[data-section-type="product"] .product-form__info-item--quantity,
[data-section-type="product"] .qty-align,
[data-section-type="product"] #myform2,
[data-section-type="product"] .qty-margin-top {
  display: none !important;
}

/* "Novo | XX Vendidos" */
[data-section-type="product"] .quantitysell {
  display: none !important;
}

/* Ícone verificado azul ao lado do título */
[data-section-type="product"] .product-meta__title .fa-check-circle {
  display: none !important;
}

/* "Vendido e enviado pela..." badge */
[data-section-type="product"] .product-meta__reference[style*="background"] {
  display: none !important;
}

/* Areviews, Ryviu, Loox placeholders */
[data-section-type="product"] .areviews_header_stars,
[data-section-type="product"] .review-widget,
[data-section-type="product"] .loox-rating {
  display: none !important;
}

/* Código do item */
[data-section-type="product"] div[style*="font-size:13px"][style*="color: #b7b7b7"] {
  display: none !important;
}

/* "DE" antes do preço riscado */
[data-section-type="product"] .price-list > span[style*="top: -5px"] {
  display: none !important;
}

/* <br> entre preço compare e preço highlight */
[data-section-type="product"] .price-list > br {
  display: none !important;
}

/* Contador / queima de estoque */
[data-section-type="product"] .contadordropmeta,
[data-section-type="product"] [class*="contadordrop"] {
  display: none !important;
}

/* Product labels (custom tags) */
[data-section-type="product"] .product-label--custom1,
[data-section-type="product"] .product-label--custom2 {
  display: none !important;
}

/* Bandeiras de pagamento seção inferior */
[data-section-type="product"] div[style*="background: #f5f5f5"][style*="border-radius: 12px"] {
  display: none !important;
}

/* ═══════════════════════════════════════════════════════
   3. BREADCRUMB — sutil como Nike
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .breadcrumb {
  padding: 12px 20px !important;
  font-size: 12px !important;
  color: #707072 !important;
  border-bottom: none !important;
  background: transparent !important;
}

[data-section-type="product"] .breadcrumb__link {
  color: #707072 !important;
  text-decoration: none !important;
}

[data-section-type="product"] .breadcrumb__link:hover {
  color: #111111 !important;
}

[data-section-type="product"] .page__sub-header {
  padding: 0 !important;
  margin: 0 !important;
}

[data-section-type="product"] .page__navigation {
  display: none !important;
}

/* ═══════════════════════════════════════════════════════
   4. LAYOUT DESKTOP
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .product-block-list {
  padding: 0 !important;
}

[data-section-type="product"] .product-block-list__wrapper {
  display: flex !important;
  flex-wrap: wrap !important;
  gap: 0 !important;
}

[data-section-type="product"] .product-block-list__item--gallery {
  flex: 1 1 55% !important;
  max-width: 55% !important;
  padding: 0 !important;
}

[data-section-type="product"] .product-block-list__item--info {
  flex: 1 1 45% !important;
  max-width: 45% !important;
  padding: 0 40px 0 40px !important;
  position: sticky !important;
  top: 80px !important;
  align-self: flex-start !important;
}

[data-section-type="product"] .product-block-list__item--description,
[data-section-type="product"] .product-block-list__item--reviews,
[data-section-type="product"] .product-block-list__item--trust,
[data-section-type="product"] .product-block-list__item--shipping,
[data-section-type="product"] .product-block-list__item--content {
  flex: 1 1 100% !important;
  max-width: 100% !important;
  padding: 0 20px !important;
}

/* ═══════════════════════════════════════════════════════
   5. GALERIA
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .product-gallery {
  border: none !important;
  border-radius: 0 !important;
  background: #f5f5f5 !important;
}

[data-section-type="product"] .product-gallery__carousel-item img,
[data-section-type="product"] .product-gallery img {
  border-radius: 0 !important;
  object-fit: cover !important;
}

[data-section-type="product"] .product-gallery__thumbnail {
  border: 2px solid transparent !important;
  border-radius: 6px !important;
  overflow: hidden !important;
  transition: border-color 0.15s ease !important;
}

[data-section-type="product"] .product-gallery__thumbnail.is-selected,
[data-section-type="product"] .product-gallery__thumbnail:hover {
  border-color: #111111 !important;
}

/* ═══════════════════════════════════════════════════════
   6. PRODUCT META — Idêntico Nike
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .product-meta {
  padding: 0 !important;
}

/* Título — Nike: 22px, weight 500, line-height 28px */
[data-section-type="product"] .product-meta__title {
  font-size: 22px !important;
  font-weight: 500 !important;
  line-height: 1.27 !important;
  letter-spacing: 0 !important;
  color: #111111 !important;
  margin-bottom: 2px !important;
  margin-top: 0 !important;
  text-transform: none !important;
  padding-right: 40px !important;
}

/* Vendor / Category — Nike: 16px, #707072, weight 400 */
[data-section-type="product"] .product-meta__vendor,
[data-section-type="product"] .product-meta__reference {
  font-size: 16px !important;
  color: #707072 !important;
  font-weight: 400 !important;
  margin-bottom: 4px !important;
  margin-top: 0 !important;
}

/* ★★★★★ Avaliações — Nike: 14px com espaço */
[data-section-type="product"] div[style*="width: 100%"][style*="margin-top: -5px"] {
  margin-top: 4px !important;
  margin-bottom: 8px !important;
}

[data-section-type="product"] .fas.fa-star {
  color: #111111 !important;
  font-size: 13px !important;
}

[data-section-type="product"] div[style*="width: 100%"] > b {
  font-size: 14px !important;
  font-weight: 400 !important;
  color: #707072 !important;
  margin-left: 4px !important;
}

/* ═══════════════════════════════════════════════════════
   7. PREÇOS — Idêntico Nike
   Nike: "R$ 1.234,99 no Pix  R$-1.299,99  5% off"
   Tudo em 1 linha, preço atual 16px #111, riscado 16px #707072, off 16px #4a8c1c
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .product-form__info-list {
  padding: 0 !important;
  border: none !important;
  margin: 0 !important;
}

[data-section-type="product"] .product-form__info-item {
  padding: 0 !important;
  border: none !important;
  margin-bottom: 0 !important;
}

[data-section-type="product"] .product-form__info-title {
  display: none !important;
}

[data-section-type="product"] .product-form__info-content {
  margin: 0 !important;
  padding: 0 !important;
}

/* Price list — tudo inline */
[data-section-type="product"] .price-list {
  display: flex !important;
  flex-wrap: nowrap !important;
  align-items: baseline !important;
  gap: 8px !important;
  margin-top: 8px !important;
  margin-bottom: 4px !important;
}

/* Preço atual */
[data-section-type="product"] .price--highlight {
  font-size: 16px !important;
  font-weight: 500 !important;
  color: #111111 !important;
}

/* Preço riscado */
[data-section-type="product"] .price--compare {
  font-size: 16px !important;
  font-weight: 400 !important;
  color: #707072 !important;
  text-decoration: line-through !important;
}

/* Porcentagem off — verde como Nike */
[data-section-type="product"] .discount__percentage {
  background: none !important;
  border: none !important;
  color: #328615 !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  padding: 0 !important;
  display: inline-flex !important;
  align-items: center !important;
}

[data-section-type="product"] .discount__percentage svg {
  display: none !important;
}

[data-section-type="product"] .align-price-discount {
  display: flex !important;
  align-items: baseline !important;
  gap: 8px !important;
  flex-wrap: nowrap !important;
}

/* ═══════════════════════════════════════════════════════
   8. SELETOR DE VARIANTES — Nike spacing
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .product-form__variants {
  margin: 20px 0 16px !important;
}

[data-section-type="product"] .product-form__option {
  margin-bottom: 16px !important;
}

/* Label "Tamanho: XX" — Nike: 16px, weight 500 */
[data-section-type="product"] .product-form__option-name {
  font-size: 16px !important;
  font-weight: 500 !important;
  color: #111111 !important;
  margin-bottom: 12px !important;
  display: block !important;
}

[data-section-type="product"] .product-form__selected-value {
  font-weight: 400 !important;
  color: #707072 !important;
}

/* Grid 5 colunas — Nike style */
[data-section-type="product"] .block-swatch-list {
  display: grid !important;
  grid-template-columns: repeat(5, 1fr) !important;
  gap: 8px !important;
}

[data-section-type="product"] .block-swatch__item {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-height: 48px !important;
  border: 1px solid #cacacb !important;
  border-radius: 8px !important;
  background: #ffffff !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  color: #111111 !important;
  cursor: pointer !important;
  transition: all 0.15s ease !important;
  padding: 8px 4px !important;
}

[data-section-type="product"] .block-swatch__item:hover {
  border-color: #111111 !important;
}

[data-section-type="product"] .block-swatch__radio:checked + .block-swatch__item {
  border-color: #111111 !important;
  border-width: 2px !important;
  font-weight: 500 !important;
}

[data-section-type="product"] .block-swatch__radio:disabled + .block-swatch__item {
  opacity: 0.3 !important;
  cursor: not-allowed !important;
  text-decoration: line-through !important;
  color: #cacacb !important;
}

/* Color swatch */
[data-section-type="product"] .color-swatch__item {
  width: 28px !important;
  height: 28px !important;
  border-radius: 50% !important;
  border: 1px solid #e5e5e5 !important;
  outline: 2px solid transparent !important;
  outline-offset: 3px !important;
  transition: outline-color 0.15s ease !important;
}

[data-section-type="product"] .color-swatch__radio:checked + .color-swatch__item {
  outline-color: #111111 !important;
}

[data-section-type="product"] .variant-swatch__item {
  border: 2px solid transparent !important;
  border-radius: 8px !important;
  overflow: hidden !important;
}

[data-section-type="product"] .variant-swatch__radio:checked + .variant-swatch__item {
  border-color: #111111 !important;
}

[data-section-type="product"] .select-wrapper--primary {
  border: 1px solid #cacacb !important;
  border-radius: 8px !important;
  background: #ffffff !important;
}

/* ═══════════════════════════════════════════════════════
   9. BOTÃO "COMPRAR AGORA" — Nike: pill preto, 60px height
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .product-form__add-button,
[data-section-type="product"] .product-form__payment-container .button--primary {
  width: 100% !important;
  background: #111111 !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 30px !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  letter-spacing: 0 !important;
  text-transform: none !important;
  padding: 0 24px !important;
  line-height: 60px !important;
  height: 60px !important;
  cursor: pointer !important;
  transition: opacity 0.2s ease !important;
  margin-top: 8px !important;
  margin-bottom: 0 !important;
}

[data-section-type="product"] .product-form__add-button:hover {
  background: #111111 !important;
  opacity: 0.7 !important;
}

[data-section-type="product"] .button--disabled {
  background: #e5e5e5 !important;
  color: #707072 !important;
  border-radius: 30px !important;
  border: none !important;
  cursor: not-allowed !important;
}

[data-section-type="product"] .shopify-payment-button__button {
  border-radius: 30px !important;
  overflow: hidden !important;
}

/* Shopify dynamic checkout — hide on Nike style */
[data-section-type="product"] .shopify-payment-button {
  margin-top: 8px !important;
}

/* ═══════════════════════════════════════════════════════
   10. BOTÃO FLUTUANTE
   ═══════════════════════════════════════════════════════ */
.botaoflutuante {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 999 !important;
  background: #ffffff !important;
  padding: 12px 20px calc(12px + env(safe-area-inset-bottom)) !important;
  box-shadow: none !important;
  border: none !important;
  border-top: none !important;
  width: 100% !important;
  max-width: 100% !important;
  transition: opacity 0.3s ease, transform 0.3s ease !important;
}

.botaoflutuante.is-hidden {
  opacity: 0 !important;
  transform: translateY(100%) !important;
  pointer-events: none !important;
}

.botaoflutuante #clicar {
  display: block !important;
  width: 100% !important;
  background: #111111 !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 30px !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  text-transform: none !important;
  padding: 18px 24px !important;
  text-align: center !important;
  letter-spacing: 0 !important;
  cursor: pointer !important;
  line-height: 1 !important;
  box-shadow: none !important;
}

.botaoflutuante #clicar:hover {
  opacity: 0.85 !important;
}

/* ═══════════════════════════════════════════════════════
   11. CARDS
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .card__title {
  font-size: 20px !important;
  font-weight: 500 !important;
  color: #111111 !important;
  text-transform: none !important;
}

[data-section-type="product"] .card__header {
  padding: 20px 0 12px !important;
  border: none !important;
}

[data-section-type="product"] .card__section {
  padding: 0 !important;
  border: none !important;
}

[data-section-type="product"] .card__collapsible-button {
  padding: 20px 0 !important;
  border-top: 1px solid #e5e5e5 !important;
  border-bottom: none !important;
  background: transparent !important;
}

[data-section-type="product"] .card__collapsible-content {
  padding: 0 0 20px !important;
}

/* ═══════════════════════════════════════════════════════
   12. FRETE
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .fretefundo {
  border: 1px solid #e5e5e5 !important;
  border-radius: 12px !important;
  padding: 12px 16px !important;
  margin-bottom: 16px !important;
  background: #f5f5f5 !important;
}

/* ═══════════════════════════════════════════════════════
   13. BADGES
   ═══════════════════════════════════════════════════════ */
#badges-product {
  margin-top: 12px !important;
}

#badges-product .badge {
  display: flex !important;
  align-items: flex-start !important;
  gap: 12px !important;
  padding: 6px 0 !important;
  border: none !important;
}

#badges-product .badge-icon {
  flex-shrink: 0 !important;
  fill: #111111 !important;
}

#badges-product .text-badge {
  font-size: 14px !important;
  color: #707072 !important;
  line-height: 1.5 !important;
  margin: 0 !important;
}

#badges-product .highlight-text {
  font-weight: 500 !important;
  color: #111111 !important;
}

/* ═══════════════════════════════════════════════════════
   14. TRUST / PAYMENT
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .payment-list { gap: 8px !important; display: flex !important; flex-wrap: wrap !important; }
[data-section-type="product"] .payment-list__item { opacity: 0.7 !important; }
[data-section-type="product"] .payment-list__item:hover { opacity: 1 !important; }

.product-recommendations .section__title,
.product-recommendations .heading {
  font-size: 22px !important;
  font-weight: 500 !important;
  color: #111111 !important;
  text-transform: none !important;
}

[data-section-type="product"] .product-form__payment-container {
  padding: 0 !important;
  margin: 0 !important;
}

/* Scrollbar */
[data-section-type="product"] .card--sticky::-webkit-scrollbar { width: 4px !important; }
[data-section-type="product"] .card--sticky::-webkit-scrollbar-thumb { background: #cacacb !important; border-radius: 4px !important; }

/* ═══════════════════════════════════════════════════════
   15. Container para variantes movidas (mobile)
   ═══════════════════════════════════════════════════════ */
#royal-variants-below-gallery {
  display: none;
}

/* ═══════════════════════════════════════════════════════
   16. AVISO "SELECIONE UM TAMANHO"
   ═══════════════════════════════════════════════════════ */
.royal-size-warning {
  color: #d32f2f !important;
  font-size: 14px !important;
  font-weight: 500 !important;
  margin-top: 10px !important;
  padding: 0 !important;
  display: none;
  align-items: center;
  gap: 6px;
  animation: royalShake 0.4s ease;
}

.royal-size-warning.is-visible {
  display: flex !important;
}

.royal-size-warning svg {
  flex-shrink: 0;
  width: 16px;
  height: 16px;
  fill: #d32f2f;
}

.royal-size-error .block-swatch__item {
  border-color: #d32f2f !important;
}

.royal-size-error .block-swatch__radio:checked + .block-swatch__item {
  border-color: #111111 !important;
}

@keyframes royalShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-6px); }
  40% { transform: translateX(6px); }
  60% { transform: translateX(-4px); }
  80% { transform: translateX(4px); }
}

/* ═══════════════════════════════════════════════════════
   17. MOBILE — Layout Nike: Info → Imagem → Variantes+Botão
   ═══════════════════════════════════════════════════════ */
@media (max-width: 999px) {
  [data-section-type="product"] .product-block-list__wrapper {
    flex-direction: column !important;
  }

  /* 1. Info (título, preço, estrelas) */
  [data-section-type="product"] .product-block-list__item--info {
    order: 1 !important;
    flex: 1 1 100% !important;
    max-width: 100% !important;
    position: relative !important;
    top: auto !important;
    padding: 16px 20px 0 !important;
  }

  /* 2. Galeria */
  [data-section-type="product"] .product-block-list__item--gallery {
    order: 2 !important;
    flex: 1 1 100% !important;
    max-width: 100% !important;
  }

  /* 3. Variantes movidas pra aqui */
  #royal-variants-below-gallery {
    order: 3 !important;
    display: block !important;
    padding: 20px 20px 0 !important;
    width: 100% !important;
  }

  .royal-mobile-hidden {
    display: none !important;
  }

  [data-section-type="product"] .product-block-list__item--description { order: 4 !important; }
  [data-section-type="product"] .product-block-list__item--content { order: 5 !important; }
  [data-section-type="product"] .product-block-list__item--reviews { order: 6 !important; }
  [data-section-type="product"] .product-block-list__item--trust { order: 7 !important; }
  [data-section-type="product"] .product-block-list__item--shipping { order: 8 !important; }

  /* Título mobile — Nike: 22px */
  [data-section-type="product"] .product-meta__title {
    font-size: 22px !important;
    line-height: 1.27 !important;
  }

  /* Grid de tamanhos 5 colunas no mobile tb */
  [data-section-type="product"] .block-swatch-list {
    grid-template-columns: repeat(5, 1fr) !important;
    gap: 7px !important;
  }

  [data-section-type="product"] .block-swatch__item {
    min-height: 48px !important;
    font-size: 14px !important;
    padding: 6px 4px !important;
  }

  /* Botão ATC mobile — Nike: full width, 56px */
  [data-section-type="product"] .product-form__add-button {
    height: 56px !important;
    line-height: 56px !important;
    font-size: 16px !important;
  }

  [data-section-type="product"] .product-block-list__item--description,
  [data-section-type="product"] .product-block-list__item--reviews,
  [data-section-type="product"] .product-block-list__item--trust,
  [data-section-type="product"] .product-block-list__item--shipping,
  [data-section-type="product"] .product-block-list__item--content {
    padding: 0 20px !important;
  }
}

/* ═══════════════════════════════════════════════════════
   18. TRANSIÇÕES
   ═══════════════════════════════════════════════════════ */
[data-section-type="product"] .block-swatch__item,
[data-section-type="product"] .color-swatch__item,
[data-section-type="product"] .variant-swatch__item,
[data-section-type="product"] .product-form__add-button,
.botaoflutuante #clicar {
  transition: all 0.15s ease !important;
}
</style>

<script>
(function(){
  'use strict';

  var hasUserSelectedSize = false;

  // ─── 1. Botão flutuante: esconde quando botão raiz visível ───
  function initFloatingToggle() {
    var floatingBar = document.getElementById('scrollToTop');
    if (!floatingBar) return;

    var mainBtn = document.querySelector('[data-section-type="product"] .product-form__add-button');
    if (!mainBtn) return;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          floatingBar.classList.add('is-hidden');
        } else {
          floatingBar.classList.remove('is-hidden');
        }
      });
    }, { root: null, rootMargin: '0px', threshold: 0.1 });

    observer.observe(mainBtn);
  }

  // ─── 2. Mobile: mover variantes/botão abaixo da galeria ───
  function moveVariantsBelowGallery() {
    if (window.innerWidth > 999) return;

    var section = document.querySelector('[data-section-type="product"]');
    if (!section) return;

    var wrapper = section.querySelector('.product-block-list__wrapper');
    if (!wrapper) return;

    if (document.getElementById('royal-variants-below-gallery')) return;

    var variants = section.querySelector('.product-form__variants');
    var paymentContainer = section.querySelector('.product-form__payment-container');

    if (!variants && !paymentContainer) return;

    var container = document.createElement('div');
    container.id = 'royal-variants-below-gallery';

    if (variants) container.appendChild(variants);
    if (paymentContainer) container.appendChild(paymentContainer);

    wrapper.appendChild(container);
  }

  // ─── 3. Esconder "pessoas vendo" (fallback JS) ───
  function hideViewerCount() {
    var olhos = document.querySelectorAll('[data-section-type="product"] .olho');
    olhos.forEach(function(el) {
      var parent = el.closest('div[style*="display: flex"]');
      if (parent) parent.style.display = 'none';
    });
  }

  // ─── 4. Encontrar option de "tamanho" ───
  function getSizeOption() {
    var sizeLabels = ['tamanho', 'size', 'tam', 'numero', 'número'];
    var options = document.querySelectorAll('[data-section-type="product"] .product-form__option');
    
    for (var i = 0; i < options.length; i++) {
      var label = options[i].querySelector('.product-form__option-name');
      if (label) {
        var text = label.textContent.toLowerCase().trim();
        for (var j = 0; j < sizeLabels.length; j++) {
          if (text.indexOf(sizeLabels[j]) !== -1) return options[i];
        }
      }
    }
    if (options.length === 1) return options[0];
    return null;
  }

  // ─── 5. Criar aviso de tamanho ───
  function createSizeWarning(sizeOption) {
    if (!sizeOption) return null;
    
    var existing = sizeOption.querySelector('.royal-size-warning');
    if (existing) return existing;

    var warning = document.createElement('div');
    warning.className = 'royal-size-warning';
    warning.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg> Selecione um tamanho para continuar';
    
    var swatchList = sizeOption.querySelector('.block-swatch-list, .color-swatch-list, .variant-swatch-list, .select-wrapper--primary');
    if (swatchList) {
      swatchList.parentNode.insertBefore(warning, swatchList.nextSibling);
    } else {
      sizeOption.appendChild(warning);
    }
    
    return warning;
  }

  // ─── 6. Monitorar seleção de tamanho ───
  function watchSizeSelection() {
    var sizeOption = getSizeOption();
    if (!sizeOption) return;

    // Escuta mudanças nos radios
    sizeOption.addEventListener('change', function() {
      hasUserSelectedSize = true;
      var warning = sizeOption.querySelector('.royal-size-warning');
      if (warning) warning.classList.remove('is-visible');
      var swatchList = sizeOption.querySelector('.block-swatch-list, .color-swatch-list, .variant-swatch-list');
      if (swatchList) swatchList.classList.remove('royal-size-error');
    });

    // Escuta cliques nos labels
    sizeOption.addEventListener('click', function(e) {
      if (e.target.closest('.block-swatch__item, .color-swatch__item, .variant-swatch__item')) {
        hasUserSelectedSize = true;
        var warning = sizeOption.querySelector('.royal-size-warning');
        if (warning) warning.classList.remove('is-visible');
        var swatchList = sizeOption.querySelector('.block-swatch-list, .color-swatch-list, .variant-swatch-list');
        if (swatchList) swatchList.classList.remove('royal-size-error');
      }
    });
  }

  // ─── 7. Validação no botão flutuante ───
  function initFloatingValidation() {
    var floatingBtn = document.getElementById('clicar');
    if (!floatingBtn) return;

    floatingBtn.addEventListener('click', function(e) {
      var sizeOption = getSizeOption();
      
      if (!sizeOption || hasUserSelectedSize) return;

      // Bloqueia
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();

      // Mostra aviso
      var warning = createSizeWarning(sizeOption);
      if (warning) warning.classList.add('is-visible');

      // Borda vermelha
      var swatchList = sizeOption.querySelector('.block-swatch-list, .color-swatch-list, .variant-swatch-list');
      if (swatchList) swatchList.classList.add('royal-size-error');

      // Scroll suave até os tamanhos
      var rect = sizeOption.getBoundingClientRect();
      var offsetTop = window.pageYOffset + rect.top - 100;
      window.scrollTo({ top: offsetTop, behavior: 'smooth' });

    }, true);
  }

  // ─── INIT ───
  function init() {
    setTimeout(function() {
      initFloatingToggle();
      moveVariantsBelowGallery();
      hideViewerCount();
      watchSizeSelection();
      initFloatingValidation();
    }, 300);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', init);
})();
</script>
