  }

  /* Container de variantes movido para abaixo da galeria */
  #royal-variants-below-gallery {
    order: 3 !important;
    display: block !important;
    padding: 16px 20px 0 !important;
    width: 100% !important;
  }

  /* Esconde variants e botão no bloco info original (ja movidos) */
